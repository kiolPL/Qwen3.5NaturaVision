<Window x:Class="NaturaVision.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NaturaVision Desktop"
        Height="820"
        Width="1240"
        MinHeight="720"
        MinWidth="980"
        Background="#E9E1D2"
        FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,3,0,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="Expander">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="26" Background="#102A24" Padding="18" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="NaturaVision" Foreground="#FFF8E7" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Rozpoznawanie roslin i grzybow lesnych"
                               Foreground="#CADCCB"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="#244D3E" CornerRadius="16" Padding="14,8" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Foreground="#F8D77A"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" CornerRadius="34" Background="#FFFDF6" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="26" Background="#DCD4C3" BorderBrush="#C4B9A5" BorderThickness="1">
                    <Grid>
                        <Image x:Name="PreviewImage" Stretch="Uniform" Margin="18" />
                        <StackPanel x:Name="PreviewPlaceholder"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="520">
                            <TextBlock Text="Wybierz obraz"
                                       Foreground="#18392E"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       TextAlignment="Center" />
                            <TextBlock Text="JPG, PNG lub WebP"
                                       Foreground="#5B625A"
                                       FontSize="15"
                                       TextAlignment="Center"
                                       Margin="0,10,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="SelectedImageText"
                                   Text="No image selected."
                                   Foreground="#51564D"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Wynik i katalog sa ponizej."
                                   Foreground="#7B776D"
                                   FontSize="12"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="ChooseImageButton"
                                Content="Wybierz"
                                Click="ChooseImageButton_Click"
                                Background="#F0E5CF" />
                        <Button x:Name="CaptureScreenButton"
                                Content="Zrzut ekranu"
                                Click="CaptureScreenButton_Click"
                                Background="#E7D8B7" />
                        <Button x:Name="ClassifyButton"
                                Content="Rozpoznaj"
                                Click="ClassifyButton_Click"
                                Background="#2F6F55"
                                Foreground="White" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="22" Background="#F8F3E8" Padding="14" Margin="0,14,0,0">
            <StackPanel>
                <Expander x:Name="PredictionExpander" Header="Wynik" IsExpanded="False">
                    <Border Background="#FFFDF6" CornerRadius="16" Padding="14" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock x:Name="PredictionLabelText"
                                       Text="No prediction yet."
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#2F6F55" />
                            <TextBlock x:Name="PredictionDetailsText"
                                       Text="Brak wyniku."
                                       Foreground="#51564D"
                                       Margin="0,6,0,0" />
                            <Grid x:Name="PredictionMediaPanel"
                                  Visibility="Collapsed"
                                  Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#E6E0D2"
                                        CornerRadius="14"
                                        Height="160"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image x:Name="PredictionSpeciesImage" Stretch="UniformToFill" />
                                        <TextBlock x:Name="PredictionSpeciesImagePlaceholder"
                                                   Text="Brak obrazu"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#5B625A"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="2">
                                    <TextBlock x:Name="PredictionDescriptionText"
                                               Text="Opis pojawi sie po rozpoznaniu."
                                               Foreground="#51564D"
                                               FontSize="14"
                                               LineHeight="20" />
                                    <TextBlock x:Name="PredictionSourceText"
                                               Text=""
                                               Foreground="#7B776D"
                                               FontSize="12"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <Expander x:Name="RuntimeExpander" Header="Ustawienia" IsExpanded="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300" Margin="0,10,0,0">
                        <StackPanel Background="#FFFDF6">
                            <Border CornerRadius="16" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Test" FontSize="16" FontWeight="Bold" Foreground="#18392E" />
                                    <DockPanel>
                                        <TextBlock Text="Liczba" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,8" />
                                        <TextBox x:Name="TestCountTextBox" Text="3" />
                                    </DockPanel>
                                    <Button x:Name="RunSuiteButton"
                                            Content="Uruchom test"
                                            Click="RunSuiteButton_Click"
                                            Background="#D2A83E" />

                                    <Separator Margin="0,14,0,14" />

                                    <TextBlock Text="Runner" FontWeight="SemiBold" />
                                    <DockPanel>
                                        <Button Content="Browse" DockPanel.Dock="Right" Click="BrowseLlamaButton_Click" />
                                        <TextBox x:Name="LlamaBinTextBox" />
                                    </DockPanel>

                                    <TextBlock Text="Model" FontWeight="SemiBold" />
                                    <DockPanel>
                                        <Button Content="Browse" DockPanel.Dock="Right" Click="BrowseModelButton_Click" />
                                        <TextBox x:Name="ModelPathTextBox" />
                                    </DockPanel>

                                    <TextBlock Text="Projektor" FontWeight="SemiBold" />
                                    <DockPanel>
                                        <Button Content="Browse" DockPanel.Dock="Right" Click="BrowseProjectorButton_Click" />
                                        <TextBox x:Name="ProjectorPathTextBox" />
                                    </DockPanel>

                                    <TextBlock Text="Zestaw testowy" FontWeight="SemiBold" />
                                    <DockPanel>
                                        <Button Content="Browse" DockPanel.Dock="Right" Click="BrowseTestJsonlButton_Click" />
                                        <TextBox x:Name="TestJsonlTextBox" />
                                    </DockPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Tokeny obrazu" FontWeight="SemiBold" />
                                            <TextBox x:Name="ImageTokensTextBox" Text="1024" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Tokeny wyniku" FontWeight="SemiBold" />
                                            <TextBox x:Name="MaxTokensTextBox" Text="24" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Warstwy GPU" FontWeight="SemiBold" />
                                    <TextBox x:Name="GpuLayersTextBox" Text="99" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Expander>

                <Expander x:Name="TaxonomyExpander" Header="Katalog" IsExpanded="False">
                    <Border Background="#FFFDF6" CornerRadius="16" Padding="12" Margin="0,10,0,0">
                        <Grid MaxHeight="360">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="480" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ListView x:Name="TaxonomyListView"
                                      SelectionChanged="TaxonomyListView_SelectionChanged">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" DisplayMemberBinding="{Binding LabelId}" Width="82" />
                                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding ScientificName}" Width="180" />
                                        <GridViewColumn Header="PL" DisplayMemberBinding="{Binding PolishName}" Width="160" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Background="#E6E0D2" CornerRadius="14">
                                    <Grid>
                                        <Image x:Name="TaxonomyImage" Stretch="UniformToFill" />
                                        <TextBlock x:Name="TaxonomyImagePlaceholder"
                                                   Text="Brak obrazu"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#5B625A"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock x:Name="TaxonomyTitleText"
                                                   Text="Wybierz pozycje"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#18392E" />
                                        <TextBlock x:Name="TaxonomyDescriptionText"
                                                   Text="Opis pojawi sie tutaj."
                                                   Foreground="#51564D"
                                                   Margin="0,8,0,0" />
                                        <TextBlock x:Name="TaxonomySourceText"
                                                   Text=""
                                                   Foreground="#7B776D"
                                                   FontSize="12"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Expander>

                <Expander x:Name="LogExpander" Header="Log" IsExpanded="False">
                    <Border Background="#171B18" CornerRadius="16" Padding="12" Margin="0,10,0,0">
                        <TextBox x:Name="LogTextBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#171B18"
                                 Foreground="#EAE6D9"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 MaxHeight="300" />
                    </Border>
                </Expander>
            </StackPanel>
        </Border>
    </Grid>
</Window>
